# -----------------------------
# Godot UAV Simulator .gitignore
# -----------------------------

# Godot editor/import caches
.godot/
.import/
*.import

# Python caches and virtual environments
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
.venv/
venv/
env/
ENV/
.pytest_cache/
.mypy_cache/

# Jupyter checkpoints
.ipynb_checkpoints/

# OS/editor noise
.DS_Store
Thumbs.db
*.tmp
*.temp
.cursor/
.idea/
.vscode/
terminal_*.txt
cursor_purpose_*.md

# Local runtime logs/artifacts
logs/*.csv
logs/*.log
logs/*.ipynb

# Experiment runtime artifacts (generated by GA/Baseline runs)
Experiments/**/tmp/
Experiments/**/tensorboard/
Experiments/**/*.tfevents*
Experiments/**/tensorboard_process.log
Experiments/**/python_server.log
Experiments/**/godot.log
Experiments/**/collision_log.csv
Experiments/**/simple_log.csv
Experiments/**/godot_summary.json
Experiments/**/oriented_graph.pkl
Experiments/**/sim_input_seed_*.json
Experiments/**/sim_output_seed_*.json

# Common generated experiment output folders
Experiments/**/baseline_runs/
Experiments/**/directed_graph_5_runs/
Experiments/**/ga_runs/
Experiments/**/runs/

# Keep repository source/docs/data tracked by default.
Godot_v4.3-stable_linux.x86_64
